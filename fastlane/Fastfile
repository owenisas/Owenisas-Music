default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Increment build number (uses the current timestamp for uniqueness)
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "Owenisas Music.xcodeproj"
    )

    # Build the app — let Xcode handle provisioning automatically
    build_app(
      scheme: "Owenisas Music",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "OwenisasMusic.ipa",
      export_options: {
        signingStyle: "automatic",
        teamID: "3LHSL95J9H"
      },
      xcargs: "-allowProvisioningUpdates"
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end

  desc "Just build (no upload)"
  lane :build_only do
    build_app(
      scheme: "Owenisas Music",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "OwenisasMusic.ipa",
      export_options: {
        signingStyle: "automatic",
        teamID: "3LHSL95J9H"
      },
      xcargs: "-allowProvisioningUpdates"
    )
  end
end
